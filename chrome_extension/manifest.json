{
    "manifest_version": 3,
    "name": "Elite Trading Bot Connector",
    "version": "1.0.0",
    "description": "Receives trading signals and executes trades on Pocket Option",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://*.pocketoption.com/*",
        "https://*.po.market/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.pocketoption.com/*",
                "https://*.po.market/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png"
        }
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png"
    }
}